{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "mcp/chrome-devtools",
  "title": "Chrome DevTools",
  "description": "Integration with Chrome DevTools for debugging and performance analysis.",
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "runtimeHint": "npx",
      "identifier": "@chrome-tools/devtools-mcp",
      "runtimeArguments": [
        {
          "name": "-y",
          "type": "positional"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "install": {
    "type": "manual"
  }
}
