{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "mcp/angular",
  "title": "Angular",
  "description": "Angular CLI integration for local development: scaffolding, component generation, build/serve, testing, and linting automation.",
  "version": "0.1.0",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "runtimeHint": "npx",
      "identifier": "@angular/mcp",
      "runtimeArguments": [
        {
          "name": "-y",
          "type": "positional"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "install": {
    "type": "manual"
  }
}
